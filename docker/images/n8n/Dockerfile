# Generated by GitHub Copilot using Claude Sonnet 4.6
# Description: n8n application image running on the N|Solid runtime.
# This is a personal fork (dmgoldstein1/n8n) configured for local deployment.
# N|Solid provides zero-code observability, CPU profiling, and OpenTelemetry
# telemetry export on top of the standard Node.js 24.x runtime.
#
# Build instructions:
#   docker build -f docker/images/n8n/Dockerfile -t n8n:local .
# Configure N|Solid telemetry at runtime via environment variables:
#   NSOLID_OTLP - exporter type (e.g. "otlp")
#   NSOLID_OTLP_CONFIG - JSON config for the OTLP endpoint

ARG NODE_VERSION=24.13.1
ARG N8N_VERSION=snapshot

# Base image comes from the custom n8n-base image which may include an
# optional N|Solid runtime if a bundle was supplied during its build.
FROM n8n-base:${NODE_VERSION}

ARG N8N_VERSION
ARG N8N_RELEASE_TYPE=dev
ENV NODE_ENV=production
ENV N8N_RELEASE_TYPE=${N8N_RELEASE_TYPE}
ENV SHELL=/bin/sh

# N|Solid runtime configuration (if present).
# NSOLID_APPNAME and NSOLID_TRACING_ENABLED are set here as sensible defaults.
# Override NSOLID_OTLP / NSOLID_OTLP_CONFIG at container runtime to ship
# telemetry to your observability stack.
ENV NSOLID_APPNAME=n8n
ENV NSOLID_TRACING_ENABLED=1

WORKDIR /home/node

# The n8n-base image already contains the nsolid binary (if supplied).
# No additional copy is required here.

COPY ./compiled /usr/local/lib/node_modules/n8n
COPY docker/images/n8n/docker-entrypoint.sh /

RUN cd /usr/local/lib/node_modules/n8n && \
    npm rebuild sqlite3 isolated-vm && \
    ln -s /usr/local/lib/node_modules/n8n/bin/n8n /usr/local/bin/n8n && \
    # Register nsolid as the node runtime for all node invocations
    ln -sf /usr/local/bin/nsolid /usr/local/bin/node && \
    mkdir -p /home/node/.n8n && \
    chown -R node:node /home/node && \
    rm -rf /root/.npm /tmp/*

EXPOSE 5678/tcp
USER node
ENTRYPOINT ["tini", "--", "/docker-entrypoint.sh"]

LABEL org.opencontainers.image.title="n8n" \
      org.opencontainers.image.description="Workflow Automation Tool" \
      org.opencontainers.image.source="https://github.com/n8n-io/n8n" \
      org.opencontainers.image.url="https://n8n.io" \
      org.opencontainers.image.version=${N8N_VERSION}
